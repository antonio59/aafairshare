{
  "name": "template",
  "version": "1.0.0",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "start": "./scripts/start-dev.sh",
    "dev": "vite",
    "dev:clean": "rm -rf node_modules/.vite && NODE_ENV=development ./scripts/start-dev.sh",
    "clean": "rm -rf node_modules/.vite",
    "build": "node scripts/build.js",
    "preview": "vite preview",
    "security:audit": "npm audit --json > npm-audit.json || true",
    "security:fix": "npm audit fix",
    "security:update": "npm update --save",
    "security:snyk": "snyk test --sarif-file-output=snyk.sarif",
    "security:snyk:license": "snyk test --license --sarif-file-output=snyk-license.sarif",
    "security:snyk:monitor": "snyk monitor --all-projects",
    "security:snyk:fix": "snyk wizard",
    "migrate:supabase": "chmod +x ./scripts/migrations/migrate-imports.sh && ./scripts/migrations/migrate-imports.sh",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run --config config/vitest/vitest.config.ts",
    "test:coverage": "vitest run --coverage",
    "test:ci": "NODE_ENV=test tsx scripts/ci-test.ts",
    "fix:ts": "tsx ./scripts/fix-typescript-issues.ts",
    "fix:ts:unused": "tsx ./scripts/fix-typescript-unused.ts",
    "fix:ts:comments": "tsx ./scripts/fix-typescript-comments.ts",
    "fix:ts:entities": "tsx ./scripts/fix-react-entities.ts",
    "test-storybook": "test-storybook",
    "test:e2e": "playwright test --config=config/playwright/playwright.config.ts",
    "test:e2e:ui": "playwright test --config=config/playwright/playwright.config.ts --ui",
    "test:performance": "tsx scripts/run-lighthouse.ts --config=config/test/lighthouse-config.json",
    "test:performance:ci": "npm run build && npx serve -s dist -p 3000 & sleep 5 && tsx scripts/run-lighthouse.ts --config=config/test/lighthouse-config.json --url=http://localhost:3000 && killall node",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "format": "prettier --write \"src/**/*.{ts,tsx,css,md}\"",
    "typecheck": "tsc --noEmit",
    "prepare-release": "node scripts/prepare-release.js",
    "release": "standard-version",
    "deploy:staging": "vercel",
    "deploy:production": "vercel --prod",
    "sentry:validate": "tsx scripts/validateSentry.ts",
    "sentry:release": "npm run sentry:validate && tsx scripts/create-sentry-release.ts",
    "sentry:sourcemaps": "./node_modules/.bin/sentry-cli sourcemaps inject ./dist && ./node_modules/.bin/sentry-cli sourcemaps upload ./dist --release=${SENTRY_RELEASE}"
  },
  "dependencies": {
    "@microsoft/fetch-event-source": "^2.0.1",
    "@sentry/browser": "^9.5.0",
    "@sentry/react": "^9.5.0",
    "@supabase/supabase-js": "2.49.1",
    "chart.js": "^4.4.1",
    "dayjs": "^1.11.13",
    "esbuild": "0.25.1",
    "@esbuild/linux-x64": "0.25.1",
    "glob": "11.0.1",
    "lucide-react": "^0.479.0",
    "pdfkit": "^0.16.0",
    "react": "^18.2.0",
    "react-chartjs-2": "^5.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "6.22.3",
    "react-virtualized-auto-sizer": "1.0.25",
    "react-window": "1.8.11",
    "uuid": "11.1.0",
    "zod": "3.24.2"
  },
  "devDependencies": {
    "@babel/plugin-transform-react-jsx": "7.25.9",
    "@eslint/js": "9.22.0",
    "@playwright/test": "^1.41.2",
    "@sentry/cli": "^2.30.2",
    "@storybook/addon-essentials": "8.6.4",
    "@storybook/addon-interactions": "^8.6.4",
    "@storybook/addon-links": "^8.6.4",
    "@storybook/blocks": "8.6.4",
    "@storybook/react": "8.6.4",
    "@storybook/react-vite": "8.6.4",
    "@storybook/test-runner": "0.22.0",
    "@tailwindcss/typography": "^0.5.16",
    "@testing-library/jest-dom": "^6.4.2",
    "@testing-library/react": "16.2.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/node": "^22.13.10",
    "@types/react": "19.0.10",
    "@types/react-dom": "19.0.4",
    "@types/react-virtualized-auto-sizer": "1.0.4",
    "@types/react-window": "1.8.8",
    "@typescript-eslint/eslint-plugin": "8.26.1",
    "@typescript-eslint/parser": "8.26.1",
    "@vitejs/plugin-react": "^4.2.1",
    "@vitest/coverage-v8": "3.0.8",
    "@vitest/ui": "3.0.8",
    "autoprefixer": "10.4.21",
    "axe-core": "^4.8.4",
    "axe-playwright": "^2.0.1",
    "chrome-launcher": "1.1.2",
    "dotenv-cli": "^8.0.0",
    "eslint": "^9.22.0",
    "eslint-import-resolver-typescript": "3.8.4",
    "eslint-plugin-import": "2.31.0",
    "eslint-plugin-react": "7.37.4",
    "eslint-plugin-react-hooks": "5.2.0",
    "eslint-plugin-react-refresh": "0.4.19",
    "globals": "16.0.0",
    "happy-dom": "17.4.3",
    "jiti": "2.4.2",
    "jsdom": "^26.0.0",
    "lighthouse": "12.4.0",
    "npm-force-resolutions": "0.0.10",
    "postcss": "8.5.3",
    "serve": "14.2.4",
    "snyk": "1.1295.4",
    "standard-version": "^9.5.0",
    "storybook": "8.6.4",
    "tailwindcss": "3.4.17",
    "terser": "5.39.0",
    "ts-node": "^10.9.2",
    "tsx": "4.19.3",
    "typescript": "5.8.2",
    "vite": "6.2.1",
    "vite-tsconfig-paths": "5.1.4",
    "vitest": "3.0.8",
    "web-vitals": "4.2.4",
    "ws": "8.18.1",
    "rollup": "4.12.0"
  },
  "optionalDependencies": {
    "@esbuild/linux-x64": "0.25.1"
  }
}
