    "jiti": "2.4.2",
    "jsdom": "^26.0.0",
    "lighthouse": "12.4.0",
    "postcss": "8.5.3",
    "postcss-import": "16.1.0",
    "postcss-nesting": "13.0.1",
    "rollup": "4.36.0",
    "serve": "14.2.4",
    "standard-version": "^9.5.0",
    "storybook": "8.6.7",
    "tailwindcss": "4.0.0",
    "terser": "5.39.0",
    "ts-jest": "29.2.6",
    "ts-node": "^10.9.2",
