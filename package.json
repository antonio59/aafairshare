{
  "name": "aa-fairshare",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "security-scan": "snyk test --severity-threshold=high && npm audit --audit-level=high --production",
    "audit-fix": "npm audit fix",
    "security:full": "npm run security-scan && npm run lint && npm run typecheck",
    "backup": "tsx scripts/createBackup.ts",
    "backup:test": "tsx scripts/testBackup.ts",
    "dev": "NODE_ENV=development vite",
    "build": "NODE_ENV=production tsc --project tsconfig.json && vite build",
    "lint": "eslint . --max-warnings 0",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit --project tsconfig.json",
    "add-categories": "node --loader ts-node/esm src/scripts/addCategories.ts",
    "postinstall": "npm run build",
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "prebuild": "npm run clean"
  },
  "dependencies": {
