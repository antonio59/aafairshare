{
  "name": "aafairshare",
  "version": "1.0.0",
  "engines": {
    "node": "20.x"
  },
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0 && npm run lint:spell",
    "lint:spell": "cspell '**/*.{ts,tsx,js,jsx,json,md}'",
    "clean": "rm -rf node_modules/.next && rm -rf node_modules && npm install --legacy-peer-deps",
    "security:check": "tsx scripts/security-check.ts",
    "migrate:supabase": "chmod +x ./scripts/migrations/migrate-imports.sh && ./scripts/migrations/migrate-imports.sh",
    "gen:types": "npx supabase gen types typescript --project-id ccwcbnfnvkmwubkuvzns --schema public > src/core/types/supabase.types.ts",
    "keep-supabase-alive": "tsx scripts/keep-supabase-alive.ts",
    "setup-supabase-cron": "chmod +x ./scripts/setup-supabase-cron.sh && ./scripts/setup-supabase-cron.sh",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:ci": "NODE_ENV=test tsx scripts/ci-test.ts",
    "fix:ts": "tsx ./scripts/fix-typescript-issues.ts",
    "fix:ts:unused": "tsx ./scripts/fix-typescript-unused.ts",
    "fix:ts:comments": "tsx ./scripts/fix-typescript-comments.ts",
    "fix:ts:entities": "tsx ./scripts/fix-react-entities.ts",
    "test-storybook": "test-storybook",
    "test:e2e": "playwright test --config=config/playwright/playwright.config.ts",
    "test:e2e:ui": "playwright test --config=config/playwright/playwright.config.ts --ui",
    "test:performance": "tsx scripts/run-lighthouse.ts --config=config/test/lighthouse-config.json",
    "test:performance:ci": "npm run build && npx serve -s dist -p 3000 & sleep 5 && tsx scripts/run-lighthouse.ts --config=config/test/lighthouse-config.json --url=http://localhost:3000 && killall node",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "format": "prettier --write \"src/**/*.{ts,tsx,css,md}\"",
    "typecheck": "tsc --noEmit",
    "prepare-release": "node scripts/prepare-release.js",
    "release": "standard-version",
    "deploy:staging": "vercel",
    "deploy:production": "vercel --prod",
    "preinstall": "npm config set --location=project audit-level=high && npm config set --location=project omit=optional && npm config set --location=project legacy-peer-deps=true"
  },
  "config": {
    "module": "commonjs"
  },
  "dependencies": {
    "@headlessui/react": "2.0.0",
    "@microsoft/fetch-event-source": "^2.0.1",
    "@radix-ui/react-checkbox": "1.1.4",
    "@radix-ui/react-dialog": "1.1.6",
    "@radix-ui/react-icons": "1.3.2",
    "@radix-ui/react-label": "2.1.2",
    "@radix-ui/react-scroll-area": "1.2.3",
    "@radix-ui/react-tabs": "1.1.3",
    "@radix-ui/react-toast": "1.2.6",
    "@radix-ui/react-tooltip": "1.1.8",
    "@supabase/ssr": "0.6.1",
    "@supabase/supabase-js": "2.49.1",
    "@types/dompurify": "3.0.5",
    "canvg": "4.0.3",
    "chart.js": "^4.4.1",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "date-fns": "^3.6.0",
    "dompurify": "3.2.4",
    "esbuild": "0.25.1",
    "glob": "^9.3.5",
    "html2canvas": "1.4.1",
    "jspdf": "3.0.1",
    "jspdf-autotable": "^5.0.2",
    "lucide-react": "0.479.0",
    "next": "14.1.3",
    "react": "19.0.0",
    "react-chartjs-2": "^5.2.0",
    "react-day-picker": "9.6.3",
    "react-dom": "19.0.0",
    "react-hot-toast": "2.5.2",
    "react-virtualized-auto-sizer": "1.0.25",
    "react-window": "1.8.11",
    "tailwind-merge": "3.0.2",
    "uuid": "^9.0.1",
    "zod": "3.24.2"
  },
  "overrides": {
    "jspdf": {
      "canvg": "4.0.3"
    },
    "canvg": "4.0.3",
    "glob": "^9.3.5",
    "rimraf": "^5.0.0",
    "inflight": "^2.0.0",
    "q": "npm:@endo/eventual-send@^1.0.0",
    "react": "19.0.0",
