{
  "name": "template",
  "version": "1.0.0",
  "type": "module",
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "start": "./scripts/start-dev.sh",
    "dev": "NODE_ENV=development ./scripts/start-dev.sh",
    "dev:clean": "rm -rf node_modules/.vite && NODE_ENV=development ./scripts/start-dev.sh",
    "clean": "rm -rf node_modules/.vite",
    "build": "npm run create-dist && npm run build:netlify-functions && npx vite build --config config/vite/vite.config.ts",
    "create-dist": "node -e \"const fs=require('fs');const dirs=['dist','netlify/functions-dist','playwright-report','test-results'];dirs.forEach(dir=>{try{if(!fs.existsSync(dir)){fs.mkdirSync(dir,{recursive:true});console.log('Created '+dir);}else{console.log(dir+' exists');}}catch(e){console.error(e);}});\"",
    "ensure-dirs": "node netlify/functions-dist/scripts/ensure-directories.js",
    "build:ci": "tsx scripts/ci-build.ts",
    "preview": "vite preview",
    "netlify:node-check": "node -e \"if (process.env.SKIP_NODE_CHECK === 'true') { console.log('Node version check skipped'); } else if (process.versions.node.split('.')[0] < 20) { console.error('❌ Node.js 20+ is required'); process.exit(1); } else { console.log('✅ Using Node.js', process.versions.node); }\"",
    "preinstall": "npm run netlify:node-check && npx npm-force-resolutions",
    "security:audit": "npm audit",
    "security:fix": "npm audit fix",
    "security:update": "npm update --save",
    "security:snyk": "snyk test",
    "security:snyk:license": "snyk test --license",
    "security:snyk:monitor": "snyk monitor",
    "security:snyk:fix": "snyk wizard",
    "migrate:supabase": "chmod +x ./scripts/migrations/migrate-imports.sh && ./scripts/migrations/migrate-imports.sh",
    "test": "vitest --config config/vitest/vitest.config.ts",
    "test:ui": "vitest --ui --config config/vitest/vitest.config.ts",
    "test:run": "vitest run --config config/vitest/vitest.config.ts",
    "test:coverage": "vitest run --coverage --config config/vitest/vitest.config.ts",
    "test:ci": "NODE_ENV=test tsx scripts/ci-test.ts",
    "fix:ts": "tsx ./scripts/fix-typescript-issues.ts",
    "fix:ts:unused": "tsx ./scripts/fix-typescript-unused.ts",
    "fix:ts:comments": "tsx ./scripts/fix-typescript-comments.ts",
    "fix:ts:entities": "tsx ./scripts/fix-react-entities.ts",
    "test-storybook": "test-storybook",
    "test:e2e": "playwright test --config=config/playwright/playwright.config.ts",
    "test:e2e:ui": "playwright test --config=config/playwright/playwright.config.ts --ui",
    "test:performance": "tsx scripts/run-lighthouse.ts --config=config/test/lighthouse-config.json",
    "test:performance:ci": "npm run build && npx serve -s dist -p 3000 & sleep 5 && tsx scripts/run-lighthouse.ts --config=config/test/lighthouse-config.json --url=http://localhost:3000 && killall node",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "lint": "eslint . --ext .ts,.tsx",
    "db:backup": "tsx scripts/db-backup.ts",
    "prepare-release": "node scripts/prepare-release.js",
    "release": "standard-version",
    "deploy:staging": "NODE_ENV=staging tsx scripts/deploy.js staging",
    "deploy:production": "NODE_ENV=production tsx scripts/deploy.js production",
    "sentry:release": "tsx scripts/create-sentry-release.ts",
    "build:netlify-functions": "tsc -p config/typescript/tsconfig.netlify.json",
    "prebuild": "tsx scripts/create-directories.ts && tsc -p config/typescript/tsconfig.netlify.json",
    "test:netlify-build": "tsx scripts/test-netlify-build.ts",
    "netlify:build": "node --loader ts-node/esm scripts/netlify-build-pure.ts"
  },
  "dependencies": {
    "@microsoft/fetch-event-source": "^2.0.1",
    "@sentry/browser": "^9.5.0",
    "@sentry/react": "^9.5.0",
    "@supabase/supabase-js": "2.49.1",
    "chart.js": "^4.4.1",
    "dayjs": "^1.11.13",
    "esbuild": "0.25.1",
    "glob": "11.0.1",
    "lucide-react": "^0.479.0",
    "pdfkit": "^0.16.0",
    "react": "^18.2.0",
    "react-chartjs-2": "^5.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "6.22.3",
    "react-virtualized-auto-sizer": "1.0.25",
    "react-window": "1.8.11",
    "uuid": "11.1.0",
    "zod": "3.24.2"
  },
  "devDependencies": {
    "@babel/plugin-transform-react-jsx": "7.25.9",
    "@eslint/js": "9.22.0",
    "@netlify/functions": "3.0.1",
    "@playwright/test": "^1.41.2",
    "@storybook/addon-essentials": "8.6.4",
    "@storybook/addon-interactions": "^8.6.4",
    "@storybook/addon-links": "^8.6.4",
    "@storybook/blocks": "8.6.4",
    "@storybook/react": "8.6.4",
    "@storybook/react-vite": "8.6.4",
    "@storybook/test-runner": "0.22.0",
    "@tailwindcss/typography": "^0.5.16",
    "@testing-library/jest-dom": "^6.4.2",
    "@testing-library/react": "16.2.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/node": "^22.13.10",
    "@types/react": "19.0.10",
    "@types/react-dom": "19.0.4",
    "@types/react-virtualized-auto-sizer": "1.0.4",
    "@types/react-window": "1.8.8",
    "@typescript-eslint/eslint-plugin": "8.26.1",
    "@typescript-eslint/parser": "8.26.1",
    "@vitejs/plugin-react": "^4.2.1",
    "@vitest/coverage-v8": "3.0.8",
    "@vitest/ui": "3.0.8",
    "autoprefixer": "10.4.21",
    "axe-core": "^4.8.4",
    "axe-playwright": "^2.0.1",
    "chrome-launcher": "1.1.2",
    "dotenv-cli": "^8.0.0",
    "eslint": "^9.22.0",
    "eslint-import-resolver-typescript": "3.8.4",
    "eslint-plugin-import": "2.31.0",
    "eslint-plugin-react": "7.37.4",
    "eslint-plugin-react-hooks": "5.2.0",
    "eslint-plugin-react-refresh": "0.4.19",
    "globals": "16.0.0",
    "happy-dom": "17.4.3",
    "jiti": "2.4.2",
    "jsdom": "^26.0.0",
    "lighthouse": "12.4.0",
    "npm-force-resolutions": "0.0.10",
    "postcss": "8.5.3",
    "serve": "14.2.4",
    "snyk": "1.1295.4",
    "standard-version": "^9.5.0",
    "storybook": "8.6.4",
    "tailwindcss": "3.4.17",
    "terser": "5.39.0",
    "ts-node": "^10.9.2",
    "tsx": "4.19.3",
    "typescript": "5.8.2",
    "vite": "6.2.1",
    "vite-tsconfig-paths": "5.1.4",
    "vitest": "3.0.8",
    "web-vitals": "4.2.4",
    "ws": "8.18.1"
  }
}
