{
  "name": "AAFairShare",
  "short_name": "AAFairShare",
  "description": "Expense sharing made simple",
  "start_url": "/",
  "scope": "/",
  "display": "standalone",
  "background_color": "#F9FAFB",
  "theme_color": "#F9FAFB",
  "orientation": "portrait",
  "icons": [
    {
      "src": "/aafairshare.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "any maskable"
    }
  ],
  "shortcuts": [
    {
      "name": "Add Expense",
      "short_name": "Add",
      "description": "Add a new expense",
      "url": "/add",
      "icons": [{ "src": "/aafairshare.png", "sizes": "192x192" }]
    },
    {
      "name": "View Analytics",
      "short_name": "Analytics",
      "description": "View expense analytics",
      "url": "/analytics",
      "icons": [{ "src": "/aafairshare.png", "sizes": "192x192" }]
    }
  ],
  "categories": ["finance", "utilities"],
  "dir": "ltr",
  "lang": "en",
  "prefer_related_applications": false,
  "related_applications": [],
  "iarc_rating_id": "",
  "share_target": {
    "action": "/add",
    "method": "POST",
    "enctype": "multipart/form-data",
    "params": {
      "title": "description",
      "text": "amount",
      "files": [
        {
          "name": "receipts",
          "accept": ["image/*"]
        }
      ]
    }
  }
}
