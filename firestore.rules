rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Common function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Allow authenticated users to read all collections
    match /expenses/{document=**} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    match /categories/{document=**} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    match /categoryGroups/{document=**} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    match /tags/{document=**} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    match /budgets/{document=**} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    match /recurringExpenses/{document=**} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    match /settlements/{document=**} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    match /users/{userId} {
      allow read: if isAuthenticated() && request.auth.uid == userId;
      allow write: if isAuthenticated() && request.auth.uid == userId;
    }

    // Deny access to any other collections by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
