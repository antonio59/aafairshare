rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return request.auth.uid == userId;
    }
    
    function isPartner() {
      return request.auth.token.email == "andypamo@gmail.com" || 
             request.auth.token.email == "antoniojsmith@protonmail.com";
    }

    // User profiles
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow write: if isOwner(userId);
    }

    // Expenses
    match /expenses/{expenseId} {
      allow read: if isAuthenticated() && isPartner();
      allow create: if isAuthenticated() && isPartner();
      allow update, delete: if isAuthenticated() && isPartner() && 
        (resource.data.createdBy == request.auth.uid);
    }

    // Budget settings
    match /budgets/{budgetId} {
      allow read: if isAuthenticated() && isPartner();
      allow write: if isAuthenticated() && isPartner();
    }

    // Categories
    match /categories/{categoryId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && isPartner();
    }

    // Settings
    match /settings/{settingId} {
      allow read: if isAuthenticated() && isOwner(settingId);
      allow write: if isAuthenticated() && isOwner(settingId);
    }

    // Deny access to all other collections by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
