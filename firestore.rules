rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Allow read/write access to all users to all documents
    match /{document=**} {
      allow read, write: if true;
    }
    
    // Categories collection
    match /categories/{categoryId} {
      allow read: if true;
      allow write: if true;
    }
    
    // Expenses collection
    match /expenses/{expenseId} {
      allow read: if true;
      allow write: if true;
    }
    
    // Tags collection
    match /tags/{tagId} {
      allow read: if true;
      allow write: if true;
    }
    
    // Budgets collection
    match /budgets/{budgetId} {
      allow read: if true;
      allow write: if true;
    }
    
    // Recurring expenses collection
    match /recurringExpenses/{recurringExpenseId} {
      allow read: if true;
      allow write: if true;
    }
    
    // Settlements collection
    match /settlements/{settlementId} {
      allow read: if true;
      allow write: if true;
    }
  }
}
