{
  "compilerOptions": {
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "noImplicitReturns": true,
    "noUnusedLocals": true,
    "outDir": "lib",
    "sourceMap": true,
    "strict": true,
    "target": "es2017",
    "baseUrl": ".",
    "rootDir": "src",
    "paths": {
      "@/*": ["src/*"],
      "shared/*": ["../app/shared/*"],
      "../../build/server/index.js": ["../build/server/index.js"],
      "../lib/remix.js": ["lib/remix.js"]
    },
    "skipLibCheck": true,
    "typeRoots": ["src/types", "node_modules/@types"],
    "types": []
  },
  "compileOnSave": true,
  "include": [
    "src",
    "src/types/*.d.ts",
    "src/types/pdfmake.d.ts"
  ],
  "exclude": ["node_modules/@types/pdfmake"]
}
