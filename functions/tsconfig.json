{
  "compilerOptions": {
    "module": "CommonJS", // Change module type
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true, // Often helpful with esModuleInterop
    "moduleResolution": "node", // Change resolution strategy
    "noImplicitReturns": true,
    "noUnusedLocals": true,
    "outDir": "lib",
    "sourceMap": true,
    "strict": true,
    "target": "es2017",
    "baseUrl": "../", // Base is now project root relative to this file
    "paths": {
      "shared/*": ["app/shared/*"] // Path relative to new baseUrl
    },
    // "rootDir": "src" // Removed to allow importing from ../app/shared
  },
  "compileOnSave": true,
  "include": [
    "src"
  ]
}
