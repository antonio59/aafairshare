{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "netlify/functions-dist",
    "rootDir": ".",
    "declaration": false,
    "sourceMap": true
  },
  "include": [
    "netlify/functions/**/*.ts",
    "netlify-build-plugin.ts",
    "scripts/ensure-directories.ts",
    "scripts/netlify-build-pure.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "src"
  ]
} 