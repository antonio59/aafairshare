{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "isolatedModules": true,
    "skipLibCheck": true,
    "outDir": "../../netlify/functions-dist",
    "types": ["node"],
    "paths": {
      "@/*": ["../../src/*"],
      "@lib/*": ["../../src/lib/*"],
      "@utils/*": ["../../src/utils/*"],
      "@config/*": ["../../config/*"]
    }
  },
  "include": [
    "../../netlify/functions/**/*.ts",
    "../../netlify/plugins/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "**/*.test.ts",
    "**/*.spec.ts"
  ]
}
