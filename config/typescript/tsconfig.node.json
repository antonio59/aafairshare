{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "composite": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowSyntheticDefaultImports": true,
    "types": ["node"],
    "paths": {
      "@/*": ["./src/*"],
      "@scripts/*": ["./scripts/*"],
      "@config/*": ["./config/*"]
    }
  },
  "include": [
    "scripts/**/*.ts",
    "config/**/*.ts",
    "netlify/**/*.ts",
    "e2e/**/*.ts"
  ]
} 