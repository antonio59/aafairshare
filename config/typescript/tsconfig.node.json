{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "composite": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowSyntheticDefaultImports": true,
    "types": ["node"],
    "paths": {
      "@/*": ["../../src/*"],
      "@scripts/*": ["../../scripts/*"],
      "@config/*": ["../*"]
    }
  },
  "include": [
    "../../scripts/**/*.ts",
    "../**/*.ts",
    "../../e2e/**/*.ts"
  ]
} 